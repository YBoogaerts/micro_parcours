<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="8v4`8j,N~-R5%5+H?4|I" x="20" y="20"><statement name="HANDLER"><block type="typescript_statement" id="bsM_W0O(!,b.p|F?OZDb"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace Parcours{" line1="   let user: string[] = [] " line2="   let userId: number[] = [] " line3="   let userState: number[]=[]" line4="" line5="    //% block=&quot;inscrire $nom avec le numéro $id&quot;" line6="    export function inscription(nom: string, id: number) {" line7="        let pos = userId.indexOf(id)" line8="        if (pos &lt; 0) {" line9="            user.push(nom)" line10="            userId.push(id)" line11="            userState.push(0)" line12="        } else {" line13="            user[pos] = nom" line14="        }" line15="    }" line16="" line17="    //% block=&quot;étape suivante pour $id&quot;" line18="    export function nextState(id: number) {" line19="        let pos2 = userId.indexOf(id)" line20="        if (pos2 &gt;= 0) {" line21="            userState[pos2]++" line22="        }" line23="    }" line24="" line25="    //% block=&quot;affiche les joueurs en console&quot;" line26="    export function printUser() {" line27="        for (let i = 0; i &lt; userId.length ; i++) {" line28="            console.log(`${i} [${userId[i]}]: ${user[i]} -&gt; étape: ${userState[i]}`);" line29="        }" line30="    }" line31="    }" numlines="32"></mutation></block></statement></block></xml>