<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="TrQo#MT;B7P%uMsA.=~v" x="0" y="0"><statement name="HANDLER"><block type="typescript_statement" id="}PiQJLkR,T_DCu!|3Htt"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace Parcours{" line1="   type Action = (userId:number, serialNumber:number, message: string)=&gt; void;" line2="   let userList: string[] = [] " line3="   let userIdList: number[] = [] " line4="   let userStateList: number[] = []" line5="   let stateActionList: Action[] = []" line6="" line7="    /**" line8="     * Définit l'action à exécuter pour une étape précise" line9="     * @param userId le numéro de l'utilisateur" line10="     * @param action le code à exécuter" line11="     */" line12="    //% block=&quot;Action à l'étape $userId&quot;" line13="    //% handlerStatement=1" line14="    //% draggableParameters=&quot;reporter&quot;" line15="    export function setAction(userId: number, action: (userId: number, serialNumber: number, message: string) =&gt; void) {" line16="        stateActionList[userId] = action" line17="        //console.log(action)" line18="    }" line19="    radio.onReceivedString(function (receivedString: string) {" line20="        // id de l'émetteur" line21="        let serial = radio.receivedPacket(RadioPacketProperty.SerialNumber)" line22="        // numéro d'utilisateur" line23="        let userId = userIdList.indexOf(serial )" line24="        // calcul de l'étape de l'utilisateur" line25="        let state = 0;" line26="        // console.log(receivedString)" line27="        if (userId &gt;= 0 ){" line28="            state = userStateList[userId];" line29="        }" line30="" line31="        // On vérifie si un handler existe pour l'état actuel" line32="        if (stateActionList[userId]) {" line33="            // On exécute le handler en lui passant les données &quot;capturées&quot;" line34="            stateActionList[userId](userId, serial, receivedString)" line35="        }" line36="    })" line37="    //% block=&quot;inscrire $nom avec le numéro $id&quot;" line38="    export function inscription(nom: string, id: number) {" line39="        let userId2 = userIdList.indexOf(id)" line40="        if (userId2 &lt; 0) {" line41="            userList.push(nom)" line42="            userIdList.push(id)" line43="            userStateList.push(0)" line44="        } else {" line45="            userList[userId2] = nom" line46="        }" line47="    }" line48="" line49="    //% block=&quot;étape suivante pour $userId&quot;" line50="    export function nextState(userId: number) {" line51="        userStateList[userId]++" line52="    }" line53="" line54="    //% block=&quot;affiche les joueurs en console&quot;" line55="    export function printUser() {" line56="        for (let i = 0; i &lt; userIdList.length ; i++) {" line57="            console.log(`${i} [${userIdList[i]}]: ${userList[i]} -&gt; étape: ${userStateList[i]}`);" line58="        }" line59="    }" line60="    }" numlines="61"></mutation></block></statement></block></xml>